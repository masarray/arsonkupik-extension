{
  "manifest_version": 3,
  "name": "ArSonKuPik",
  "short_name": "ArSonKuPik",
  "description": "Professional local browser audio enhancer with parametric EQ, dynamics, harmonics, stereo width, limiting, and output routing.",
  "version": "0.3.102",
  "minimum_chrome_version": "116",
  "action": {
    "default_popup": "popup.html",
    "default_title": "ArSonKuPik",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": [
    "activeTab",
    "tabCapture",
    "offscreen",
    "storage"
  ],
  "host_permissions": [],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png",
    "512": "icons/icon-512.png"
  },
  "options_page": "studio.html",
  "version_name": "0.3.102",
  "homepage_url": "https://masarray.github.io/ArSonKuPik/"
}
