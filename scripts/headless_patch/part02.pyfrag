s=sub(s,r'\n  if \(!current\[STORE_KEYS\.domainOutputRoutes\]\) \{.*?\n  \}','', 'route defaults')
s=one(s,"  const routes = stored[STORE_KEYS.domainOutputRoutes] || {};\n  const enhancePrefs = stored[STORE_KEYS.domainEnhancePrefs] || {};\n  const customPresets = stored[STORE_KEYS.customPresets] || [];\n  const siteDomains = new Set([...Object.keys(routes), ...Object.keys(enhancePrefs)]);","  const enhancePrefs = stored[STORE_KEYS.domainEnhancePrefs] || {};\n  const customPresets = stored[STORE_KEYS.customPresets] || [];\n  const siteDomains = new Set(Object.keys(enhancePrefs));",'privacy route vars').replace("    outputRouteCount: Object.keys(routes).length,\n",'')
s=sub(s,r'async function clearSitePreferences\(\) \{.*?\n\}',"async function clearSitePreferences() {\n  await chrome.storage.local.set({ [STORE_KEYS.domainEnhancePrefs]: {} });\n  return { ok: true, privacy: await getPrivacyStatus(), state: await getStateWithPresets() };\n}",'clear prefs')
s=s.replace("    STORE_KEYS.domainOutputRoutes,\n",'').replace("  const domainRoutes = stored[STORE_KEYS.domainOutputRoutes] || {};\n",'')
