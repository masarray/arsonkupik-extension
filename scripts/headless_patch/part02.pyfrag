s=one(s,"  if (Number(tabId) === Number(studioTabId)) {\n    studioTabId = null;\n    clearStoredStudioTabId().catch(() => {});\n  }","  if (Number(tabId) === Number(studioTabId)) {\n    studioTabId = null;\n    safeSendMessage({ target: 'offscreen', type: 'SET_MONITORING_ACTIVE', active: false });\n    clearStoredStudioTabId().catch(() => {});\n  }",'studio close')
